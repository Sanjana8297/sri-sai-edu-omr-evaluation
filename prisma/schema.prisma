generator client {
  provider = "prisma-client-js"
}

// Prisma reads the Postgres URI from .env — not the Supabase MCP URL (that is only for Cursor tools).
// Supabase dashboard: Project Settings → Database → Connection string → URI (postgresql://...)
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Teacher {
  id             String          @id @default(cuid())
  email          String          @unique
  passwordHash   String
  name           String
  category       String
  students       Student[]
  questionPapers QuestionPaper[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Student {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  name         String
  category     String
  teacherId    String
  teacher      Teacher       @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  examAttempts ExamAttempt[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model QuestionPaper {
  id              String   @id @default(cuid())
  teacherId       String
  teacher         Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  category        String
  title           String
  questionContent String
  keyContent      String   @default("")
  createdAt       DateTime @default(now())
}

model ExamAttempt {
  id            String   @id @default(cuid())
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  category      String
  title         String
  examDate      DateTime
  marksObtained Float
  maxMarks      Float
  analysis      String
  createdAt     DateTime @default(now())
}
