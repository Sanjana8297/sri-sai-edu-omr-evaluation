generator client {
  provider = "prisma-client-js"
}

// Prisma reads the Postgres URI from .env — not the Supabase MCP URL (that is only for Cursor tools).
// Supabase dashboard: Project Settings → Database → Connection string → URI (postgresql://...)
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Teacher {
  id             String          @id @default(cuid())
  email          String          @unique
  passwordHash   String
  name           String
  category       String
  students       Student[]
  questionPapers QuestionPaper[]
  exams          Exam[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Student {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  name         String
  category     String
  teacherId    String
  teacher      Teacher       @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  examAttempts ExamAttempt[]
  examSessions ExamSession[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model QuestionPaper {
  id                 String   @id @default(cuid())
  teacherId          String
  teacher            Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  category           String
  title              String
  questionContent    String
  keyContent         String   @default("")
  isAiGenerated      Boolean  @default(false)
  aiPromptVersion    String?
  aiConfig           Json?
  generationMeta     Json?
  /// Public HTTPS URL only — binary lives in Supabase Storage, not in Postgres.
  questionPaperUrl   String?
  /// Public HTTPS URL only — binary lives in Supabase Storage, not in Postgres.
  answerSheetUrl     String?
  exams              Exam[]
  createdAt          DateTime @default(now())
}

model Exam {
  id              String        @id @default(cuid())
  teacherId       String
  teacher         Teacher       @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  questionPaperId String
  questionPaper   QuestionPaper @relation(fields: [questionPaperId], references: [id], onDelete: Cascade)
  category        String
  title           String
  startTime       DateTime
  endTime         DateTime
  durationMinutes Int
  isPublished     Boolean       @default(false)
  examSessions    ExamSession[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([teacherId, startTime])
  @@index([questionPaperId])
}

model ExamSession {
  id                 String            @id @default(cuid())
  examId             String
  exam               Exam              @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId          String
  student            Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  startedAt          DateTime          @default(now())
  submittedAt        DateTime?
  status             ExamSessionStatus @default(IN_PROGRESS)
  violationCount     Int               @default(0)
  cameraGranted      Boolean?
  micGranted         Boolean?
  autoSubmittedReason String?
  proctoringEvents   ProctoringEvent[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@unique([examId, studentId])
  @@index([studentId, startedAt])
}

model ProctoringEvent {
  id         String             @id @default(cuid())
  sessionId  String
  session    ExamSession        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  eventType  ProctoringEventType
  occurredAt DateTime           @default(now())
  metadata   Json?
  createdAt  DateTime           @default(now())

  @@index([sessionId, occurredAt])
}

model ExamAttempt {
  id            String   @id @default(cuid())
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  category      String
  title         String
  examDate      DateTime
  marksObtained Float
  maxMarks      Float
  analysis      String
  createdAt     DateTime @default(now())
}

enum ExamSessionStatus {
  IN_PROGRESS
  SUBMITTED
  AUTO_SUBMITTED
}

enum ProctoringEventType {
  TAB_HIDDEN
  WINDOW_BLUR
  PERMISSION_DENIED
  PERMISSION_REVOKED
  CAMERA_MISSING
  MIC_MISSING
  HEARTBEAT
}
